# Advisor Appointment Scheduler — environment template
# Copy to `.env` and fill in values. Do not commit real secrets.

# -----------------------------------------------------------------------------
# App
# -----------------------------------------------------------------------------
APP_ENV=development
APP_HOST=0.0.0.0
APP_PORT=8000
TIMEZONE=Asia/Kolkata
CHANNEL_DEFAULT=chat
# Comma-separated frontend origins allowed to call the API (required on Vercel)
# CORS_ORIGINS=https://your-frontend.vercel.app,http://localhost:5173

# -----------------------------------------------------------------------------
# LLM / agent (Phase 2+) — Google Gemini
# -----------------------------------------------------------------------------
LLM_PROVIDER=gemini
GEMINI_API_KEY=
LLM_MODEL=gemini-2.0-flash
LLM_TEMPERATURE=0.2
LLM_CONFIDENCE_THRESHOLD=0.6

# -----------------------------------------------------------------------------
# Secure post-call details link (no PII in-session)
# -----------------------------------------------------------------------------
SECURE_LINK_BASE=https://example.com/prebook
SECURE_LINK_SECRET=

# -----------------------------------------------------------------------------
# Google Workspace / actual FastMCP tools (Phase 3+)
# Credentials: use either service account JSON path OR OAuth client secrets
# -----------------------------------------------------------------------------
GOOGLE_APPLICATION_CREDENTIALS=
GOOGLE_OAUTH_CLIENT_SECRETS=credentials.json
GOOGLE_CALENDAR_ID=
GOOGLE_DOCS_PREBOOKINGS_ID=
GMAIL_DRAFT_TO=
ADVISOR_EMAIL=

# FastMCP server
MCP_SERVER_HOST=127.0.0.1
MCP_SERVER_PORT=8001

# Optional: domain-wide delegation subject for service accounts (Gmail)
# GOOGLE_IMPERSONATE_USER=advisor@yourdomain.com

# OAuth token cache path (created after first consent)
GOOGLE_OAUTH_TOKEN_PATH=.secrets/google_token.json
# Vercel: paste authorized-user token JSON as a single-line secret instead of a file
# GOOGLE_OAUTH_TOKEN_JSON=

# -----------------------------------------------------------------------------
# Domain / data
# -----------------------------------------------------------------------------
MOCK_CALENDAR_PATH=data/mock_calendar.json
BOOKING_CODE_PREFIX=NL-

# -----------------------------------------------------------------------------
# Session store (Phase 2: memory; optional Redis later)
# -----------------------------------------------------------------------------
SESSION_STORE=memory
# REDIS_URL=redis://localhost:6379/0

# -----------------------------------------------------------------------------
# Voice adapters (Phase 5 — leave blank until then)
# -----------------------------------------------------------------------------
# STT_PROVIDER=
# STT_API_KEY=
# TTS_PROVIDER=
# TTS_API_KEY=
